{% extends 'base.html.twig' %}

{% block title %}Mes contacts{% endblock %}

{% block body %}
<div {{ react_component('PageTransition') }}></div>
<div style="min-height:100vh; display:flex; flex-direction:column; background:#FF701F;">
    <div {{ react_component('Header', {
        'firstname': app.user ? app.user.firstname : null,
        'lastname':  app.user ? app.user.lastname  : null,
        'email':     app.user ? app.user.email     : null
    }) }}></div>
    <div {{ react_component('WhiteBar') }}></div>

    <div style="flex:1; display:flex; flex-direction:column; align-items:center; padding:3rem 1.5rem;">
        <div style="width:100%; max-width:640px;">

            <a href="{{ path('app_account_history') }}"
               style="display:inline-flex; align-items:center; gap:0.5rem; margin-bottom:1.5rem;
                      color:rgba(255,255,255,0.85); font-size:0.875rem; font-weight:600; text-decoration:none;">
                <svg xmlns="http://www.w3.org/2000/svg" style="width:1.1rem;height:1.1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Retour à l'historique
            </a>

            <h1 style="font-family:'Thunder-Extra-Bold',sans-serif; font-size:clamp(2rem,8vw,4rem); color:#fff; margin:0 0 2rem;">MES CONTACTS</h1>

            {% for msg in app.flashes('success') %}
                <div style="background:#d1fae5; color:#065f46; border-radius:0.75rem; padding:0.75rem 1rem; margin-bottom:1rem; font-size:0.875rem;">{{ msg }}</div>
            {% endfor %}
            {% for msg in app.flashes('error') %}
                <div style="background:#fee2e2; color:#dc2626; border-radius:0.75rem; padding:0.75rem 1rem; margin-bottom:1rem; font-size:0.875rem;">{{ msg }}</div>
            {% endfor %}

            {# Formulaire ajout #}
            <div style="background:#fff; border-radius:1.25rem; padding:2rem; margin-bottom:1.5rem; box-shadow:0 4px 20px rgba(0,0,0,0.08);">
                <h2 style="font-size:1rem; font-weight:700; color:#111827; margin:0 0 1.25rem;">Ajouter un contact</h2>
                <form method="POST" action="{{ path('app_contacts') }}" style="display:flex; flex-direction:column; gap:0.875rem;">
                    <input type="hidden" name="_token" value="{{ csrf_token('add-contact') }}">
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;">
                        <input type="text" name="firstname" placeholder="Prénom" required
                            style="padding:0.7rem 1rem; border:1.5px solid #e5e7eb; border-radius:0.75rem; font-size:0.875rem; outline:none;">
                        <input type="text" name="lastname" placeholder="Nom" required
                            style="padding:0.7rem 1rem; border:1.5px solid #e5e7eb; border-radius:0.75rem; font-size:0.875rem; outline:none;">
                    </div>
                    <input type="email" name="email" placeholder="Email" required
                        style="padding:0.7rem 1rem; border:1.5px solid #e5e7eb; border-radius:0.75rem; font-size:0.875rem; outline:none;">
                    <button type="submit"
                        style="padding:0.75rem; background:#FF701F; color:#fff; border:none; border-radius:0.75rem; font-weight:700; font-size:0.9rem; cursor:pointer;">
                        Ajouter
                    </button>
                </form>
            </div>

            {# Liste contacts #}
            <div style="display:flex; flex-direction:column; gap:0.625rem;">
                {% if contacts is empty %}
                    <div style="background:rgba(255,255,255,0.15); border-radius:1rem; padding:2rem; text-align:center; color:rgba(255,255,255,0.7); font-size:0.9rem;">
                        Aucun contact pour l'instant.
                    </div>
                {% else %}
                    {% for contact in contacts %}
                    <div style="background:#fff; border-radius:0.875rem; padding:0.875rem 1.25rem; display:flex; align-items:center; gap:1rem; box-shadow:0 1px 4px rgba(0,0,0,0.06);">
                        <div style="width:2.5rem; height:2.5rem; border-radius:50%; background:#fff7ed; display:flex; align-items:center; justify-content:center; font-weight:700; color:#FF701F; font-size:0.9rem; flex-shrink:0;">
                            {{ contact.firstname|slice(0,1)|upper }}
                        </div>
                        <div style="flex:1; min-width:0;">
                            <p style="font-weight:700; color:#111827; font-size:0.9rem; margin:0;">{{ contact.firstname }} {{ contact.lastname }}</p>
                            <p style="font-size:0.75rem; color:#9ca3af; margin:0;">{{ contact.email }}</p>
                        </div>
                        <form method="POST" action="{{ path('app_contacts_delete', {id: contact.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-contact-' ~ contact.id) }}">
                            <button type="submit" style="background:none; border:none; cursor:pointer; color:#d1d5db; padding:0.25rem;" title="Supprimer">
                                <i class="fa-solid fa-trash" style="font-size:0.85rem;"></i>
                            </button>
                        </form>
                    </div>
                    {% endfor %}
                {% endif %}
            </div>

        </div>
    </div>
    <div {{ react_component('Footer') }}></div>
</div>
{% endblock %}
