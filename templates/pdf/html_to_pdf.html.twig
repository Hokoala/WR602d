{% extends 'base.html.twig' %}

{% block title %}HTML to PDF{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(30px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .anim-card { animation: fadeUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.1s both; }

        .conv-label {
            display: block;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #6b7280;
            margin-bottom: 0.5rem;
        }

        /* Cache l'input natif complètement */
        #html-pdf-form input[type="file"] {
            position: fixed !important;
            top: -9999px !important;
            left: -9999px !important;
            width: 1px !important;
            height: 1px !important;
            opacity: 0 !important;
            pointer-events: none !important;
        }

        .file-zone {
            width: 100%;
            box-sizing: border-box;
            border: 2px dashed #e5e7eb;
            border-radius: 0.875rem;
            background: #f9fafb;
            padding: 2rem 1rem;
            text-align: center;
            cursor: pointer;
            transition: border-color 0.2s, background 0.2s;
            display: block;
        }
        .file-zone:hover {
            border-color: #3B82F6;
            background: #eff6ff;
        }
        .file-zone.selected {
            border-color: #3B82F6;
            background: #eff6ff;
        }

        .tab-active-blue {
            background: #3B82F6;
            color: #fff;
            box-shadow: 0 4px 16px rgba(59,130,246,0.35);
        }
        .tab-inactive {
            background: transparent;
            color: #6b7280;
        }
        .tab-inactive:hover { background: #f3f4f6; color: #374151; }
    </style>
{% endblock %}

{% block body %}
    <div {{ react_component('PageTransition') }}></div>

    <div style="min-height:100vh; display:flex; flex-direction:column; background:#3B82F6;">
        <div {{ react_component('Header', {
            'firstname': app.user ? app.user.firstname : null,
            'lastname':  app.user ? app.user.lastname  : null,
            'email':     app.user ? app.user.email     : null
        }) }}></div>
        <div {{ react_component('WhiteBar') }}></div>

        <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:3rem 1.5rem;">

            <div class="anim-card" style="width:100%; max-width:560px;">

                {# Tabs #}
                <div style="display:flex; background:#fff; border-radius:1rem; padding:0.375rem; box-shadow:0 1px 4px rgba(0,0,0,0.08); margin-bottom:1.75rem; gap:0.375rem;">
                    <a href="{{ path('app_generate_pdf') }}"
                       class="tab-inactive"
                       style="flex:1; display:flex; align-items:center; justify-content:center; gap:0.5rem;
                              padding:0.75rem 1rem; border-radius:0.75rem; font-weight:700; font-size:0.875rem;
                              text-decoration:none; transition:all 0.2s;">
                        <svg xmlns="http://www.w3.org/2000/svg" style="width:1rem;height:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                        </svg>
                        URL → PDF
                    </a>
                    <a href="{{ path('app_html_to_pdf') }}"
                       class="tab-active-blue"
                       style="flex:1; display:flex; align-items:center; justify-content:center; gap:0.5rem;
                              padding:0.75rem 1rem; border-radius:0.75rem; font-weight:700; font-size:0.875rem;
                              text-decoration:none; transition:all 0.2s;">
                        <svg xmlns="http://www.w3.org/2000/svg" style="width:1rem;height:1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                        </svg>
                        HTML → PDF
                    </a>
                </div>

                {# Card formulaire #}
                <div style="background:#fff; border-radius:1.5rem; padding:2.5rem; box-shadow:0 4px 24px rgba(0,0,0,0.08);">

                    {# En-tête #}
                    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem;">
                        <div style="width:3rem; height:3rem; border-radius:0.875rem; background:#eff6ff; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <svg xmlns="http://www.w3.org/2000/svg" style="width:1.4rem;height:1.4rem;" fill="none" viewBox="0 0 24 24" stroke="#3B82F6" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                            </svg>
                        </div>
                        <div>
                            <h1 class="font-thunder" style="font-size:1.75rem; color:#111827; line-height:1; margin-bottom:0.2rem;">HTML VERS PDF</h1>
                            <p style="font-size:0.8rem; color:#9ca3af;">Importez un fichier HTML et convertissez-le en PDF.</p>
                        </div>
                    </div>

                    {# Form #}
                    {{ form_start(form, {'action': path('app_html_to_pdf'), 'method': 'POST', 'attr': {'style': 'display:flex;flex-direction:column;gap:1.25rem;', 'enctype': 'multipart/form-data', 'id': 'html-pdf-form'}}) }}

                        <div>
                            <span class="conv-label">Fichier HTML</span>

                            {# Input caché rendu par Symfony #}
                            {{ form_widget(form.htmlFile, {'attr': {'id': 'html-file-input', 'accept': '.html'}}) }}

                            {# Zone cliquable custom #}
                            <div class="file-zone" id="dropzone">
                                <div id="dropzone-content">
                                    <svg xmlns="http://www.w3.org/2000/svg" style="width:2.5rem;height:2.5rem;color:#d1d5db;margin:0 auto 0.75rem;display:block;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                    <p style="font-size:0.75rem; color:#9ca3af;">Fichier .html uniquement</p>
                                </div>
                            </div>
                        </div>

                        <button type="submit"
                            style="width:100%; padding:0.9rem; background:#3B82F6; color:#fff; border:none;
                                   border-radius:0.875rem; cursor:pointer; font-weight:700; font-size:1rem;
                                   transition:background 0.2s; letter-spacing:0.01em;"
                            onmouseover="this.style.background='#2563eb'"
                            onmouseout="this.style.background='#3B82F6'">
                            Générer le PDF
                        </button>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div {{ react_component('Footer') }}></div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const zone    = document.getElementById('dropzone');
            const content = document.getElementById('dropzone-content');

            // Trouve l'input file dans le form (peu importe son ID généré par Symfony)
            const input = document.querySelector('#html-pdf-form input[type="file"]');

            if (!input || !zone || !content) return;

            // Clic sur la zone → ouvre le sélecteur de fichier
            zone.addEventListener('click', function () {
                input.click();
            });

            // Fichier sélectionné → met à jour la zone
            input.addEventListener('change', function () {
                if (this.files && this.files[0]) {
                    zone.classList.add('selected');
                    content.innerHTML =
                        '<svg xmlns="http://www.w3.org/2000/svg" style="width:2.5rem;height:2.5rem;color:#3B82F6;margin:0 auto 0.75rem;display:block;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">' +
                            '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />' +
                        '</svg>' +
                        '<p style="font-size:0.875rem;font-weight:600;color:#3B82F6;">' + this.files[0].name + '</p>' +
                        '<p style="font-size:0.75rem;color:#9ca3af;margin-top:0.25rem;">Fichier sélectionné</p>';
                }
            });
        });
    </script>
{% endblock %}
