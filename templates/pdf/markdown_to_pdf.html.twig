{% extends 'base.html.twig' %}

{% block title %}Markdown to PDF{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @keyframes fadeUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
        .anim-card { animation: fadeUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.1s both; }
        .conv-label { display:block; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#6b7280; margin-bottom:0.5rem; }
        #md-pdf-form input[type="file"] { position:fixed!important; top:-9999px!important; left:-9999px!important; width:1px!important; height:1px!important; opacity:0!important; pointer-events:none!important; }
        .file-zone { width:100%; box-sizing:border-box; border:2px dashed #e5e7eb; border-radius:0.875rem; background:#f9fafb; padding:2rem 1rem; text-align:center; cursor:pointer; transition:border-color 0.2s, background 0.2s; display:block; }
        .file-zone:hover, .file-zone.selected { border-color:#7C3AED; background:#f5f3ff; }
    </style>
{% endblock %}

{% block body %}
    <div {{ react_component('PageTransition') }}></div>

    <div style="min-height:100vh; display:flex; flex-direction:column; background:#7C3AED;">
        <div {{ react_component('Header', {
            'firstname': app.user ? app.user.firstname : null,
            'lastname':  app.user ? app.user.lastname  : null,
            'email':     app.user ? app.user.email     : null
        }) }}></div>
        <div {{ react_component('WhiteBar') }}></div>

        <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:3rem 1.5rem;">
            <div class="anim-card" style="width:100%; max-width:560px;">

                <a href="{{ path('app_generate_pdf') }}"
                   style="display:inline-flex; align-items:center; gap:0.5rem; margin-bottom:1.5rem; color:rgba(255,255,255,0.85); font-size:0.875rem; font-weight:600; text-decoration:none; transition:color 0.2s;"
                   onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.85)'">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width:1.1rem;height:1.1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Retour aux outils
                </a>

                <div style="background:#fff; border-radius:1.5rem; padding:2.5rem; box-shadow:0 4px 24px rgba(0,0,0,0.08);">
                    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem;">
                        <div style="width:3rem; height:3rem; border-radius:0.875rem; background:rgba(124,58,237,0.12); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <i class="fa-solid fa-hashtag" style="font-size:1.3rem; color:#7C3AED;"></i>
                        </div>
                        <div>
                            <h1 style="font-family:'Thunder-Extra-Bold',sans-serif; font-size:1.75rem; color:#111827; line-height:1; margin-bottom:0.2rem;">MARKDOWN VERS PDF</h1>
                            <p style="font-size:0.8rem; color:#9ca3af;">Convertissez un fichier Markdown en PDF.</p>
                        </div>
                    </div>

                    {{ form_start(form, {'attr': {'id': 'md-pdf-form', 'style': 'display:flex;flex-direction:column;gap:1.25rem;', 'enctype': 'multipart/form-data'}}) }}
                        <div>
                            <span class="conv-label">Fichier Markdown</span>
                            {{ form_widget(form.mdFile, {'attr': {'accept': '.md,.markdown,.txt'}}) }}
                            <div class="file-zone" id="dropzone-md">
                                <div id="dropzone-md-content">
                                    <svg xmlns="http://www.w3.org/2000/svg" style="width:2.5rem;height:2.5rem;color:#d1d5db;margin:0 auto 0.75rem;display:block;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                    <p style="font-size:0.75rem; color:#9ca3af;">Fichier .md uniquement</p>
                                </div>
                            </div>
                        </div>

                        <button type="submit"
                            style="width:100%; padding:0.9rem; background:#7C3AED; color:#fff; border:none; border-radius:0.875rem; cursor:pointer; font-weight:700; font-size:1rem; transition:background 0.2s;"
                            onmouseover="this.style.background='#6d28d9'" onmouseout="this.style.background='#7C3AED'">
                            Générer le PDF
                        </button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div {{ react_component('Footer') }}></div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const zone    = document.getElementById('dropzone-md');
            const content = document.getElementById('dropzone-md-content');
            const input   = document.querySelector('#md-pdf-form input[type="file"]');
            if (!input || !zone) return;
            zone.addEventListener('click', () => input.click());
            input.addEventListener('change', function () {
                if (this.files && this.files[0]) {
                    zone.classList.add('selected');
                    content.innerHTML =
                        '<i class="fa-solid fa-check-circle" style="font-size:2rem;color:#7C3AED;display:block;margin:0 auto 0.5rem;text-align:center;"></i>' +
                        '<p style="font-size:0.875rem;font-weight:600;color:#7C3AED;">' + this.files[0].name + '</p>' +
                        '<p style="font-size:0.75rem;color:#9ca3af;margin-top:0.25rem;">Fichier sélectionné</p>';
                }
            });
        });
    </script>
{% endblock %}
