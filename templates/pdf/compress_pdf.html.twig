{% extends 'base.html.twig' %}

{% block title %}Compress PDF{% endblock %}

{% block body %}
    <div {{ react_component('PageTransition') }}></div>

    <div style="min-height:100vh; display:flex; flex-direction:column; background:#F59E0B;">
        <div {{ react_component('Header', {
            'firstname': app.user ? app.user.firstname : null,
            'lastname':  app.user ? app.user.lastname  : null,
            'email':     app.user ? app.user.email     : null
        }) }}></div>
        <div {{ react_component('WhiteBar') }}></div>

        <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:3rem 1.5rem;">
            <div style="width:100%; max-width:560px;">

                <a href="{{ path('app_generate_pdf') }}"
                   style="display:inline-flex; align-items:center; gap:0.5rem; margin-bottom:1.5rem; color:rgba(255,255,255,0.85); font-size:0.875rem; font-weight:600; text-decoration:none;">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width:1.1rem;height:1.1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Retour aux outils
                </a>

                <div style="background:#fff; border-radius:1.5rem; padding:2.5rem; box-shadow:0 4px 24px rgba(0,0,0,0.08); text-align:center;">
                    <div style="width:4rem; height:4rem; border-radius:1rem; background:rgba(245,158,11,0.12); display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem;">
                        <i class="fa-solid fa-compress" style="font-size:1.75rem; color:#F59E0B;"></i>
                    </div>
                    <h1 style="font-family:'Thunder-Extra-Bold',sans-serif; font-size:2rem; color:#111827; margin:0 0 0.75rem;">COMPRESS PDF</h1>
                    <p style="color:#9ca3af; font-size:0.9rem; margin:0 0 1.5rem;">Cette fonctionnalité sera disponible prochainement.</p>
                    <span style="display:inline-block; background:rgba(245,158,11,0.1); color:#F59E0B; font-size:0.8rem; font-weight:700; padding:0.4rem 1rem; border-radius:0.75rem;">Bientôt disponible</span>
                </div>
            </div>
        </div>

        <div {{ react_component('Footer') }}></div>
    </div>
{% endblock %}
