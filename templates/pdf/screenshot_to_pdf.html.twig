{% extends 'base.html.twig' %}

{% block title %}Screenshot to PDF{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @keyframes fadeUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:translateY(0); } }
        .anim-card { animation: fadeUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.1s both; }
        .conv-label { display:block; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#6b7280; margin-bottom:0.5rem; }
        .conv-input { width:100%; box-sizing:border-box; padding:0.9rem 1.1rem; border-radius:0.875rem; border:2px solid #e5e7eb; background:#f9fafb; color:#111827; font-size:0.95rem; outline:none; transition:border-color 0.2s, box-shadow 0.2s; }
        .conv-input:focus { border-color:#0D9488; box-shadow:0 0 0 4px rgba(13,148,136,0.12); background:#fff; }
        .conv-input::placeholder { color:#9ca3af; }
    </style>
{% endblock %}

{% block body %}
    <div {{ react_component('PageTransition') }}></div>

    <div style="min-height:100vh; display:flex; flex-direction:column; background:#0D9488;">
        <div {{ react_component('Header', {
            'firstname': app.user ? app.user.firstname : null,
            'lastname':  app.user ? app.user.lastname  : null,
            'email':     app.user ? app.user.email     : null
        }) }}></div>
        <div {{ react_component('WhiteBar') }}></div>

        <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:3rem 1.5rem;">
            <div class="anim-card" style="width:100%; max-width:560px;">

                <a href="{{ path('app_generate_pdf') }}"
                   style="display:inline-flex; align-items:center; gap:0.5rem; margin-bottom:1.5rem; color:rgba(255,255,255,0.85); font-size:0.875rem; font-weight:600; text-decoration:none; transition:color 0.2s;"
                   onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.85)'">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width:1.1rem;height:1.1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Retour aux outils
                </a>

                <div style="background:#fff; border-radius:1.5rem; padding:2.5rem; box-shadow:0 4px 24px rgba(0,0,0,0.08);">
                    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem;">
                        <div style="width:3rem; height:3rem; border-radius:0.875rem; background:rgba(13,148,136,0.12); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <i class="fa-solid fa-camera" style="font-size:1.3rem; color:#0D9488;"></i>
                        </div>
                        <div>
                            <h1 style="font-family:'Thunder-Extra-Bold',sans-serif; font-size:1.75rem; color:#111827; line-height:1; margin-bottom:0.2rem;">SCREENSHOT VERS PDF</h1>
                            <p style="font-size:0.8rem; color:#9ca3af;">Capturez une page web en image et exportez en PDF.</p>
                        </div>
                    </div>

                    {{ form_start(form, {'attr': {'style': 'display:flex;flex-direction:column;gap:1.25rem;'}}) }}
                        <div>
                            <label class="conv-label">Adresse URL</label>
                            {{ form_widget(form.url, {'attr': {'class': 'conv-input', 'placeholder': 'https://exemple.com'}}) }}
                        </div>

                        <button type="submit"
                            style="width:100%; padding:0.9rem; background:#0D9488; color:#fff; border:none; border-radius:0.875rem; cursor:pointer; font-weight:700; font-size:1rem; transition:background 0.2s;"
                            onmouseover="this.style.background='#0f766e'" onmouseout="this.style.background='#0D9488'">
                            Capturer en PDF
                        </button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div {{ react_component('Footer') }}></div>
    </div>
{% endblock %}
