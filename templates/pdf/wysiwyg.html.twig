{% extends 'base.html.twig' %}

{% block title %}WYSIWYG to PDF{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
    <style>
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(30px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .anim-card { animation: fadeUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.1s both; }

        #quill-editor {
            height: 360px;
            background: #fff;
            border-radius: 0 0 0.5rem 0.5rem;
            font-size: 0.95rem;
        }
        .ql-toolbar.ql-snow {
            border-radius: 0.5rem 0.5rem 0 0;
            border: 1.5px solid #e5e7eb;
            border-bottom: none;
            background: #f9fafb;
        }
        .ql-container.ql-snow {
            border: 1.5px solid #e5e7eb;
            border-radius: 0 0 0.5rem 0.5rem;
        }
        .ql-editor.ql-blank::before {
            font-style: normal;
            color: #9ca3af;
        }
    </style>
{% endblock %}

{% block body %}
    <div {{ react_component('PageTransition') }}></div>

    <div style="min-height:100vh; display:flex; flex-direction:column; background:#6366F1;">
        <div {{ react_component('Header', {
            'firstname': app.user ? app.user.firstname : null,
            'lastname':  app.user ? app.user.lastname  : null,
            'email':     app.user ? app.user.email     : null
        }) }}></div>
        <div {{ react_component('WhiteBar') }}></div>

        <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:3rem 1.5rem;">

            <div class="anim-card" style="width:100%; max-width:760px;">

                {# Bouton retour #}
                <a href="{{ path('app_convert') }}"
                   style="display:inline-flex; align-items:center; gap:0.5rem; margin-bottom:1.5rem;
                          color:rgba(255,255,255,0.85); font-size:0.875rem; font-weight:600;
                          text-decoration:none; transition:color 0.2s;"
                   onmouseover="this.style.color='#fff'"
                   onmouseout="this.style.color='rgba(255,255,255,0.85)'">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width:1.1rem;height:1.1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Retour aux outils
                </a>

                {# Card #}
                <div style="background:#fff; border-radius:1.5rem; padding:2.5rem; box-shadow:0 4px 24px rgba(0,0,0,0.08);">

                    {# En-tête #}
                    <div style="display:flex; align-items:center; gap:1rem; margin-bottom:2rem;">
                        <div style="width:3rem; height:3rem; border-radius:0.875rem; background:#eef2ff; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                            <svg xmlns="http://www.w3.org/2000/svg" style="width:1.4rem;height:1.4rem;" fill="none" viewBox="0 0 24 24" stroke="#6366F1" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                            </svg>
                        </div>
                        <div>
                            <h1 class="font-thunder" style="font-size:1.75rem; color:#111827; line-height:1; margin-bottom:0.2rem;">ÉDITEUR WYSIWYG</h1>
                            <p style="font-size:0.8rem; color:#9ca3af;">Rédigez votre contenu avec mise en forme et convertissez-le en PDF.</p>
                        </div>
                    </div>

                    {# Messages flash #}
                    {% for msg in app.flashes('error') %}
                        <div style="background:#fee2e2; color:#dc2626; border-radius:0.75rem; padding:0.75rem 1rem; margin-bottom:1rem; font-size:0.875rem;">
                            {{ msg }}
                        </div>
                    {% endfor %}

                    {# Form #}
                    <form action="{{ path('app_convert_wysiwyg') }}" method="POST" id="wysiwyg-form"
                          style="display:flex; flex-direction:column; gap:1.5rem;">
                        <input type="hidden" name="_token" value="{{ csrf_token('wysiwyg-pdf') }}">
                        <input type="hidden" name="wysiwyg_content" id="wysiwyg_content">

                        <div>
                            <span style="display:block; font-size:0.72rem; font-weight:700; text-transform:uppercase;
                                         letter-spacing:0.06em; color:#6b7280; margin-bottom:0.5rem;">Contenu</span>
                            <div id="quill-editor"></div>
                        </div>

                        <button type="submit" id="submit-btn"
                            style="width:100%; padding:0.9rem; background:#6366F1; color:#fff; border:none;
                                   border-radius:0.875rem; cursor:pointer; font-weight:700; font-size:1rem;
                                   transition:background 0.2s; letter-spacing:0.01em;"
                            onmouseover="this.style.background='#4f46e5'"
                            onmouseout="this.style.background='#6366F1'">
                            Générer le PDF
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div {{ react_component('Footer') }}></div>
    </div>

    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <script>
        const quill = new Quill('#quill-editor', {
            theme: 'snow',
            placeholder: 'Rédigez votre document ici…',
            modules: {
                toolbar: [
                    [{ header: [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ color: [] }, { background: [] }],
                    [{ list: 'ordered' }, { list: 'bullet' }],
                    [{ align: [] }],
                    ['blockquote', 'code-block'],
                    ['link'],
                    ['clean']
                ]
            }
        });

        document.getElementById('wysiwyg-form').addEventListener('submit', function (e) {
            const html = quill.root.innerHTML;
            if (quill.getText().trim().length === 0) {
                e.preventDefault();
                alert('Le contenu ne peut pas être vide.');
                return;
            }
            document.getElementById('wysiwyg_content').value = html;
        });
    </script>
{% endblock %}
