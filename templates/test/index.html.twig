{% extends 'base.html.twig' %}

{% block title %}{{ pageTitle }}{% endblock %}

{% block stylesheets %}
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 2rem;
            background-color: #f5f5f5;
        }
        h1 {
            color: #333;
        }
        .card-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }
        .card {
            background: #fff;
            border-radius: 8px;
            padding: 1.5rem;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
        }
        .card h2 {
            margin: 0 0 0.5rem;
            color: #0056b3;
        }
        .card p {
            margin: 0;
            color: #666;
        }
    </style>
{% endblock %}

{% block body %}
    <h1>{{ pageTitle }}</h1>
    <p>Bienvenue sur la page de test.</p>

    <div class="card-list">
        {% for item in items %}
            <div class="card">
                <h2>{{ item.title }}</h2>
                <p>{{ item.description }}</p>
            </div>
        {% endfor %}
    </div>
{% endblock %}
