{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe{% endblock %}

{% block body %}
<div class="min-h-screen flex">

    {# ── Gauche : formulaire ── #}
    <div class="w-full lg:w-1/2 flex flex-col justify-center px-8 md:px-16 py-12 bg-white">

        <h1 class="font-thunder text-[48px] md:text-[60px] text-gray-900 leading-[1] mb-2">NOUVEAU MOT DE PASSE</h1>
        <p class="text-gray-400 text-sm mb-8">Choisissez un nouveau mot de passe sécurisé.</p>

        {{ form_start(resetForm, {'attr': {'class': 'flex flex-col gap-5', 'novalidate': 'novalidate'}}) }}

            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">
                    Nouveau mot de passe
                </label>
                {{ form_widget(resetForm.plainPassword.first, {'attr': {
                    'class': 'w-full border-2 border-gray-300 rounded-xl px-4 py-3 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#FF701F] focus:border-[#FF701F] transition',
                    'placeholder': '12 caractères minimum'
                }}) }}
                {{ form_errors(resetForm.plainPassword.first) }}
            </div>

            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">
                    Confirmer le mot de passe
                </label>
                {{ form_widget(resetForm.plainPassword.second, {'attr': {
                    'class': 'w-full border-2 border-gray-300 rounded-xl px-4 py-3 text-sm text-gray-800 focus:outline-none focus:ring-2 focus:ring-[#FF701F] focus:border-[#FF701F] transition',
                    'placeholder': 'Répétez le mot de passe'
                }}) }}
                {{ form_errors(resetForm.plainPassword.second) }}
            </div>

            <button type="submit"
                class="w-full bg-[#FF701F] hover:bg-orange-600 text-white font-thunder text-[22px] py-3.5 rounded-xl transition-all shadow-md tracking-wide">
                RÉINITIALISER
            </button>

        {{ form_end(resetForm) }}
    </div>

    {# ── Droite : visuel ── #}
    <div class="hidden lg:flex w-1/2 bg-[#FF701F] flex-col items-center justify-center relative overflow-hidden">
        <div class="absolute top-[-80px] right-[-80px] w-80 h-80 rounded-full bg-white/10"></div>
        <div class="absolute bottom-[-60px] left-[-60px] w-64 h-64 rounded-full bg-white/10"></div>

        <div class="relative z-10 flex flex-col items-center text-center px-12">
            <div class="w-32 h-32 bg-white/20 rounded-3xl flex items-center justify-center mb-8 shadow-xl">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                </svg>
            </div>
            <h2 class="font-thunder text-[60px] text-white leading-[1] mb-4">SÉCURISEZ VOTRE COMPTE</h2>
            <p class="text-white/80 text-base leading-relaxed max-w-sm">
                Choisissez un mot de passe fort avec au moins 6 caractères.
            </p>
        </div>
    </div>

</div>
{% endblock %}
