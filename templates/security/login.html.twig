{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <div {{ react_component('PageTransition') }}></div>
    <h1>Connexion</h1>

    {% if error %}
        <p style="color:red;">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
    {% endif %}

    <form method="post">
        <div>
            <label for="username">Email :</label>
            <input type="email" id="username" name="_username" value="{{ last_username }}" required autofocus>
        </div>
        <div>
            <label for="password">Mot de passe :</label>
            <input type="password" id="password" name="_password" required>
        </div>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <button type="submit">Se connecter</button>
    </form>

    <p><a href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a></p>
{% endblock %}
